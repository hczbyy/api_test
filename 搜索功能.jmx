      <hashTree>
        <LoopController guiclass="LoopControlPanel" testclass="LoopController" testname="模糊搜索">
          <stringProp name="LoopController.loops">10</stringProp>
        </LoopController>
        <hashTree>
          <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="CSV 数据文件设置">
            <stringProp name="filename">E:/jmeter_pratice/auto_takeout/data/模糊搜索响应断言.txt</stringProp>
