            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 断言 判断金额逻辑是否对应" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">// 1. 获取响应内容
String response = prev.getResponseDataAsString();

// 2. 解析 JSON
def json = new groovy.json.JsonSlurper().parseText(response);

// 3. 获取数据
def items = json.data.items;
def total = json.data.total;

// 4. 计算 sum(price * quantity)
def calculatedTotal = 0.0;
items.each { item -&gt;
    calculatedTotal += item.price * item.quantity;
}

// 5. 断言验证（保留两位小数比较）
if (Math.abs(calculatedTotal - total) &gt; 0.01) {
    AssertionResult.setFailure(true);
    AssertionResult.setFailureMessage(
        &quot;金额校验失败！\n&quot; +
        &quot;计算总和: &quot; + String.format(&quot;%.2f&quot;, calculatedTotal) + &quot;\n&quot; +
        &quot;接口返回: &quot; + String.format(&quot;%.2f&quot;, total) + &quot;\n&quot; +
        &quot;差值: &quot; + String.format(&quot;%.2f&quot;, Math.abs(calculatedTotal - total))
    );
} else {
    AssertionResult.setFailure(false);
}

// 可选：控制台打印日志用于调试
log.info(&quot;=== 金额校验通过 ===&quot;);
log.info(&quot;计算总和: &quot; + calculatedTotal);
log.info(&quot;接口返回: &quot; + total);</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223Assertion>
