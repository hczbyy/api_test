              <stringProp name="script">import groovy.json.JsonOutput

// 1. 文件路径
String csvPath = &quot;C:/Users/51298/Desktop/管理账号密码/test_cart.csv&quot;;
File csvFile = new File(csvPath);

// 2. 检查文件是否存在
if (!csvFile.exists()) {
    log.error(&quot;❌ 文件不存在: &quot; + csvPath);
    AssertionResult.setFailure(true);
    AssertionResult.setFailureMessage(&quot;CSV 文件不存在: &quot; + csvPath);
    return;
}

// 3. 读取所有行
def lines = csvFile.readLines(&quot;UTF-8&quot;);
log.info(&quot;总行数: &quot; + lines.size());

// 4. 处理数据：跳过表头（第0行）和最后1行
int startRow = 1;
int endRow = lines.size() - 2;  // 跳过最后1行

def items = [];
int validCount = 0;
int skipCount = 0;

for (int i = startRow; i &lt;= endRow; i++) {
    def line = lines[i].trim();
    
    // 跳过空行
    if (line == &quot;&quot;) {
        log.info(&quot;第 &quot; + i + &quot; 行为空行，已跳过&quot;);
        skipCount++;
        continue;
    }
    
    // 按逗号分割
    def parts = line.split(&quot;,&quot;);
    
    // 检查是否有足够的列
    if (parts.length &lt; 2) {
        log.warn(&quot;第 &quot; + i + &quot; 行列数不足，已跳过: &quot; + line);
        skipCount++;
        continue;
    }
    
    // 提取并清理数据
    def foodIdStr = parts[0].trim();
    def quantityStr = parts[1].trim();
    def codeStr = parts.length &gt; 2 ? parts[2].trim() : &quot;0&quot;;
    
    // 验证 food_id 是否为有效数字
    if (!foodIdStr.matches(&quot;\\d+&quot;)) {
        log.warn(&quot;第 &quot; + i + &quot; 行 food_id 无效，已跳过: &quot; + foodIdStr);
        skipCount++;
        continue;
    }
    
    // 验证 quantity 是否为有效数字
    if (!quantityStr.matches(&quot;\\d+&quot;)) {
        log.warn(&quot;第 &quot; + i + &quot; 行 quantity 无效，已跳过: &quot; + quantityStr);
        skipCount++;
        continue;
    }
    
    // 验证 code（如果有）是否为有效数字
    int code = 0;
    if (codeStr != &quot;&quot; &amp;&amp; codeStr.matches(&quot;\\d+&quot;)) {
        code = Integer.parseInt(codeStr);
    }
    
    // 只处理 code 为 0 的商品
    if (code == 0) {
        int foodId = Integer.parseInt(foodIdStr);
        int quantity = Integer.parseInt(quantityStr);
        
        // 额外验证：food_id 和 quantity 必须大于 0
        if (foodId &gt; 0 &amp;&amp; quantity &gt; 0) {
            items.add([
                food_id: foodId,
                quantity: quantity
            ]);
            validCount++;
            log.info(&quot;✅ 第 &quot; + i + &quot; 行有效: food_id=&quot; + foodId + &quot;, quantity=&quot; + quantity);
        } else {
            log.warn(&quot;第 &quot; + i + &quot; 行数值无效（≤0），已跳过&quot;);
            skipCount++;
        }
    } else {
        log.info(&quot;第 &quot; + i + &quot; 行 code=&quot; + code + &quot; 不为0，已跳过&quot;);
        skipCount++;
    }
}

// 5. 检查是否有有效数据
if (items.isEmpty()) {
    log.error(&quot;❌ 没有有效的商品数据！&quot;);
    AssertionResult.setFailure(true);
    AssertionResult.setFailureMessage(&quot;CSV 中没有有效的商品数据&quot;);
    return;
}

// 6. 构建请求体
def requestBody = [
    items: items,
    address: &quot;18/415&quot;,
    remark: &quot;无&quot;,
    code: &quot;&quot;
];

String jsonBody = JsonOutput.toJson(requestBody);
vars.put(&quot;orderJson&quot;, jsonBody);

log.info(&quot;========== 处理结果 ==========&quot;);
log.info(&quot;有效商品数: &quot; + validCount);
log.info(&quot;跳过行数: &quot; + skipCount);
log.info(&quot;生成 JSON: &quot; + jsonBody);</stringProp>
