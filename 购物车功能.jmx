            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 后置处理程序" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonBuilder

// 获取购物车数组变量
String cartStr = vars.get(&quot;order_items&quot;)
def dat = new JsonSlurper().parseText(cartStr)
def bodyList = []

// 循环组装下单商品结构
dat.each { item -&gt;
    def temp = [
        food_id: item.id,
        quantity: item.quantity
    ]
    bodyList.add(temp)
}

// 组装最终请求JSON
def finalBody = [
    items: bodyList,
    address: &quot;415&quot;
]

// 转为字符串存入JMeter变量
String reqJson = new JsonBuilder(finalBody).toString()
vars.put(&quot;order_body&quot;, reqJson)
log.info(&quot;生成下单请求体：&quot; + reqJson)</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
